{
  "name": "resume-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "dev": "RESUME_OS_LOCAL_ONLY=1 next dev --hostname 127.0.0.1 -p 3001",
    "build": "next build",
    "start": "RESUME_OS_LOCAL_ONLY=1 next start --hostname 127.0.0.1",
    "start:server": "next start --hostname 0.0.0.0",
    "test": "vitest run",
    "test:production-extraction": "next build && node scripts/smoke-document-extraction.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "release": "release-it --ci --config .release-it.cjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "latest",
    "@napi-rs/canvas": "0.1.80",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "ai": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "mammoth": "^1.12.0",
    "motion": "^12.42.2",
    "next": "latest",
    "next-intl": "^4.13.1",
    "pdf-parse": "^2.4.5",
    "react": "latest",
    "react-dom": "latest",
    "react-rnd": "^10.5.3",
    "tailwind-merge": "latest",
    "three": "^0.185.1",
    "yauzl": "3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@release-it/conventional-changelog": "11.0.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "^0.185.1",
    "@types/yauzl": "3.4.0",
    "autoprefixer": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "latest",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "latest",
    "release-it": "20.2.1",
    "tailwindcss": "latest",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.33.0"
}
