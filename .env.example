OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
# Comma-separated exact host[:port] values for browser BYOK providers beyond api.openai.com.
RESUME_OS_ALLOWED_AI_HOSTS=
# Use "vercel" only on Vercel, or "cloudflare" only behind Cloudflare.
RESUME_OS_TRUSTED_PROXY=
